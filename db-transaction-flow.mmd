%% =====================================================
%% 2. ファイル構成
%% =====================================================

graph LR
    subgraph Files["📁 関連ファイル"]
        A[main.go] 
        B[rdb_connection.go]
        C[db_middleware.go]
        D[rdb_handler.go]
        E[config/db.go]
    end
    
    A -->|"NewConnection()"| B
    A -->|"DBMiddleware()"| C
    C -->|"config.DBKey"| E
    B -->|"ExecFromCtx()"| D

