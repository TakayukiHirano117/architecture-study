%% DBトランザクションの流れ - Mermaidダイアグラム集
%% =====================================================

%% =====================================================
%% 1. 全体像
%% =====================================================

flowchart TB
    subgraph Startup["🚀 アプリケーション起動"]
        A[main.go] --> B[rdb.NewConnection]
        B --> C[sqlx.DB 接続確立]
        C --> D[DBMiddleware 登録]
    end
    
    subgraph Request["📥 リクエスト処理"]
        E[HTTPリクエスト] --> F{HTTPメソッド判定}
        F -->|POST/PUT/DELETE/PATCH| G[トランザクション開始]
        F -->|GET| H[通常接続を使用]
        G --> I[Contextにセット]
        H --> I
        I --> J[ハンドラー処理]
        J --> K{エラー発生?}
        K -->|Yes| L[Rollback]
        K -->|No| M[Commit]
    end
    
    subgraph Repository["💾 Repository層"]
        N[ExecFromCtx] --> O[Contextから取得]
        O --> P[RDBHandler]
    end
    
    J --> N

